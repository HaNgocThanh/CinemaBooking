# ============================================
# Cinema Booking System - Backend .gitignore
# ============================================
# This file should be in /src/ directory
# It covers both .NET Backend and Node.js Frontend

# ============================================
# 🔴 CRITICAL - Build Outputs (NEVER COMMIT)
# ============================================
## .NET Build outputs
bin/
obj/
.vs/
.vscode/
.idea/

## Build artifacts
*.dll
*.exe
*.pdb
*.so
*.dylib
*.lib
*.a

## NuGet package cache
*.nupkg
*.snupkg
packages/
.nuget/

## User-specific files (IDE settings)
*.user
*.suo
*.userosscache
*.sln.docstates
.vscode/settings.json
.idea/
*.swp
*.swo

## Visual Studio cache
.vs/
.vscode/
.localhistory/

# ============================================
# 🔐 CRITICAL - Secrets & Configuration
# ============================================
## Environment variables (NEVER COMMIT!)
.env
.env.local
.env.*.local
*.env
.env.example.local

## ASP.NET Core sensitive configs
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json
appsettings.*.json
!appsettings.json

## User secrets
secrets.json
user-secrets.json
secrets.local.json

## Connection strings with credentials
*.local

## AWS & Cloud credentials
.aws/
.gcloud/

# ============================================
# 📊 Database & Migrations
# ============================================
## Database files (local dev only)
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.ndf

## Generated SQL migration scripts
migration*.sql
*.sql.bak
Database/migrations/*.sql

# ============================================
# 📝 Logs, Temp Files & Reports
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.tmp/
*.temp
*.bak

## Test reports & coverage
test-results/
TestResults/
coverage/
htmlcov/
*.trx
.nyc_output/

# ============================================
# 🎯 Frontend (React/Node) - Node Modules
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

## Dependency lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

## npm cache
.npm/
.eslintcache
.node_repl_history

# ============================================
# 📦 Frontend - Build Output
# ============================================
dist/
build/
.next/
out/

## Vite
.vite/

## Environment variables for frontend
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# Frontend - Development & Testing
# ============================================
.DS_Store
*.pem
.idea/
.vscode/settings.json

## Testing
coverage/
.nyc_output/

# ============================================
# IDE & Editor Files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.sublime-project
.sublime-workspace

## VS Code
.vscode/
!.vscode/extensions.json

## IntelliJ
.idea/
*.iml
*.iws
*.ipr

# ============================================
# OS Specific Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.gitkeep

# ============================================
# Docker & Container Files
# ============================================
.docker/
docker-compose.override.yml

# ============================================
# Temporary & Backup Files
# ============================================
*.tmp
*.temp
*.bak
*.backup
*.old
*~
.tmp/

# ============================================
# IDE Generated Files
# ============================================
.netproject/
.project
.classpath

# ============================================
# Miscellaneous
# ============================================
.env.*.local
.cache/
.parcel-cache/
dist-ssr/
*.local

# ============================================
# Keep these (Important for repo)
# ============================================
!.gitkeep
!.github/
!.gitignore
